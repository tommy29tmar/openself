{
  "name": "openself",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "next dev",
    "dev:watch": "bash scripts/dev-watch.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src next.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:init": "npx tsx scripts/migrate.ts",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:seed:uat": "EXTENDED_SECTIONS=true INVITE_CODES=code1 npx tsx scripts/seed-uat-profiles.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "worker:build": "tsup src/worker.ts --format cjs --out-dir dist --external better-sqlite3",
    "worker:start": "node dist/worker.js",
    "worker:check": "node dist/worker.js --health-check"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1",
    "@ai-sdk/google": "^1",
    "@ai-sdk/openai": "^1",
    "@node-rs/argon2": "^2.0.2",
    "ai": "^4",
    "arctic": "^3.7.0",
    "better-sqlite3": "^11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "drizzle-orm": "^0.38",
    "fast-xml-parser": "^5.5.3",
    "lucide-react": "^0.575.0",
    "markdown-it": "^14.1.1",
    "next": "^15",
    "nodemailer": "^8.0.2",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.5.0",
    "yauzl-promise": "^4.0.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/yauzl-promise": "^4.0.1",
    "drizzle-kit": "^0.30",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "postcss": "^8",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
