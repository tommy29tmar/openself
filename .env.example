# === LLM Provider (choose one) ===

# Option A: OpenAI
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Option B: Anthropic
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Option C: Google
# AI_PROVIDER=google
# GOOGLE_API_KEY=...

# Option D: Local (Ollama)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3

# === Cost guardrails ===
LLM_DAILY_TOKEN_LIMIT=150000
LLM_MONTHLY_COST_LIMIT_USD=25
LLM_DAILY_COST_WARNING_USD=1
LLM_DAILY_COST_HARD_LIMIT_USD=2
LLM_HARD_STOP=true

# === Authentication ===
# AUTH_V2=true                    # Enable email+password signup/login
# PROFILE_ID_CANONICAL=true       # Use profile_id only (no session_id fallback)
# NEXT_PUBLIC_BASE_URL=https://openself.dev  # Required for OAuth callback URLs

# === OAuth (optional — buttons appear only when configured) ===

# Google OAuth
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# GitHub OAuth
# GITHUB_CLIENT_ID=Iv1.abc123...
# GITHUB_CLIENT_SECRET=ghp_...

# Discord OAuth
# DISCORD_CLIENT_ID=123456789012345678
# DISCORD_CLIENT_SECRET=...

# LinkedIn OAuth
# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...

# Twitter/X OAuth
# TWITTER_CLIENT_ID=...
# TWITTER_CLIENT_SECRET=...

# Apple OAuth (requires Apple Developer account)
# APPLE_CLIENT_ID=com.example.app        # Services ID
# APPLE_TEAM_ID=XXXXXXXXXX               # 10-char Team ID
# APPLE_KEY_ID=XXXXXXXXXX                # Key ID
# APPLE_PRIVATE_KEY=...                   # Base64-encoded PKCS#8 private key
