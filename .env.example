# === LLM Provider (choose one) ===

# Option A: OpenAI
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Option B: Anthropic
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Option C: Google
# AI_PROVIDER=google
# GOOGLE_API_KEY=...

# Option D: Local (Ollama)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3

# === Multi-provider tier routing (recommended for production) ===
# Format: AI_MODEL_<TIER>=<provider>:<model-id>
# Recognized provider prefixes: google, openai, anthropic, ollama.
# Unknown prefix (e.g. "llama3.2:latest") is treated as plain model-id using AI_PROVIDER.
#
# Recommended setup (Anthropic + Google):
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
#
# AI_MODEL_FAST=google:gemini-2.0-flash          # $0.075/M input — translation, schema
# AI_MODEL_STANDARD=anthropic:claude-sonnet-4-6  # $3/M input    — chat (user-facing)
# AI_MODEL_REASONING=google:gemini-2.5-pro       # $1.25/M input — conformity analysis

# === Cost guardrails ===
LLM_DAILY_TOKEN_LIMIT=150000
LLM_DAILY_COST_WARNING_USD=1
LLM_DAILY_COST_HARD_LIMIT_USD=2
# Set to false to suspend all budget enforcement (useful for UAT / beta testing)
LLM_HARD_STOP=true

# === Authentication ===
# AUTH_V2 defaults to true. Set AUTH_V2=false to opt out (legacy username-only registration).
# AUTH_V2=false
# PROFILE_ID_CANONICAL=true       # Use profile_id only (no session_id fallback)
# NEXT_PUBLIC_BASE_URL=https://openself.dev  # Required for OAuth callback URLs

# === OAuth (optional — buttons appear only when configured) ===

# Google OAuth
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# GitHub OAuth
# GITHUB_CLIENT_ID=Iv1.abc123...
# GITHUB_CLIENT_SECRET=ghp_...

# Discord OAuth
# DISCORD_CLIENT_ID=123456789012345678
# DISCORD_CLIENT_SECRET=...

# LinkedIn OAuth
# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...

# Twitter/X OAuth
# TWITTER_CLIENT_ID=...
# TWITTER_CLIENT_SECRET=...

# Apple OAuth (requires Apple Developer account)
# APPLE_CLIENT_ID=com.example.app        # Services ID
# APPLE_TEAM_ID=XXXXXXXXXX               # 10-char Team ID
# APPLE_KEY_ID=XXXXXXXXXX                # Key ID
# APPLE_PRIVATE_KEY=...                   # Base64-encoded PKCS#8 private key

# === Connectors ===

# Spotify (connector — separate from Spotify as auth provider)
# SPOTIFY_CLIENT_ID=...
# SPOTIFY_CLIENT_SECRET=...

# Strava
# STRAVA_CLIENT_ID=...
# STRAVA_CLIENT_SECRET=...

# === Voice ===
# NEXT_PUBLIC_VOICE_ENABLED=true
# NEXT_PUBLIC_VOICE_STT_SERVER_FALLBACK_ENABLED=true
# VOICE_STT_SERVER_FALLBACK_ENABLED=true   # Server-side gate for /api/transcribe route
# STT_SERVICE_URL=http://stt:8080    # Internal URL for STT container
